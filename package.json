{
  "name": "com.catchya.pdfviewer",
  "private": true,
  "version": "1.0.0",
  "description": "PDF Viewer extension for Adobe After Effects 2020 (CEP 9)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "copy-cep": "node scripts/copy-cep.mjs",
    "cep:install": "npm run build && npm run copy-cep"
  },
  "dependencies": {
    "pdfjs-dist": "^2.16.105",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
