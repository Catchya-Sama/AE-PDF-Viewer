{
  "compilerOptions": {
    "composite": true,
    "target": "ES2015",
    "lib": ["ES2015"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true
  },
  "include": ["vite.config.ts", "scripts/**/*.mjs"]
}